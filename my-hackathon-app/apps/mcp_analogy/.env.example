# Design by Analogy MCP
MCP_HOST=0.0.0.0
MCP_PORT=8124

# Optional OpenAI-compatible LLM used to enrich generated analogies.
# If ANALOGY_LLM_BASE_URL is empty, the service falls back to deterministic local logic.
ANALOGY_LLM_BASE_URL=http://localhost:1234/v1
ANALOGY_LLM_MODEL=local-model
ANALOGY_LLM_API_KEY=
ANALOGY_LLM_TIMEOUT=60
ANALOGY_LLM_ENABLED=true
