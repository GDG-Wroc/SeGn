# Backend FastAPI
PORT=8080

# MCP service URLs.
# Local defaults:
TRIZ_MCP_URL=http://localhost:8123/mcp
ANALOGY_MCP_URL=http://localhost:8124/mcp

# Shared OpenAI-compatible LLM endpoint used as fallback by backend response builders.
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL=local-model

# Optional per-pipeline overrides. If empty, backend falls back to LOCAL_LLM_*.
TRIZ_LLM_BASE_URL=
TRIZ_LLM_MODEL=
ANALOGY_RESPONSE_LLM_BASE_URL=
ANALOGY_RESPONSE_LLM_MODEL=
